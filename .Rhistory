# calculate the inner product for a random, N-dimensional vector
average_inner_product <- function(n, nsim=1000) {
## n = dimension of the vector
## returns the mean inner product of 2 vectors of length n
thetas <- numeric(nsim)
for (i in 1:nsim) {
# generate 2 random, norm 1 vectors
v1 <- rnorm(n); v1 <- v1 / sqrt(sum(v1 * v1))
v2 <- rnorm(n); v2 <- v2 / sqrt(sum(v2 * v2))
# get inner product
inner_product <- sum(v1 * v2)
# calculate theta = arccos(inner_product)
thetas[i] <- acos(inner_product)
}
thetas
}
average_inner_product(3)
hist(average_inner_product(3))
hist(average_inner_product(10))
hist(average_inner_product(100))
# calculate the inner product for a random, N-dimensional vector
average_inner_product <- function(n, nsim=1000) {
## n = dimension of the vector
## returns the mean inner product of 2 vectors of length n
thetas <- numeric(nsim)
for (i in 1:nsim) {
# generate 2 random, norm 1 vectors
v1 <- rnorm(n); v1 <- v1 / sqrt(sum(v1 * v1))
v2 <- rnorm(n); v2 <- v2 / sqrt(sum(v2 * v2))
# get inner product
inner_product <- sum(v1 * v2)
# calculate theta = arccos(inner_product)
thetas[i] <- acos(inner_product) * 2 / pi
}
thetas
}
hist(average_inner_product(100))
